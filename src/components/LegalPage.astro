---
import BaseLayout from '../layouts/BaseLayout.astro';

type Section = {
  title: string;
  body: string[];
};

type Props = {
  title: string;
  description: string;
  canonicalPath: string;
  lang: 'en' | 'ko';
  heading: string;
  updatedAt: string;
  homeHref: string;
  languageLabel: string;
  languageHref: string;
  languageCode: 'en' | 'ko';
  alternates: Array<{ lang: string; path: string }>;
  sections: Section[];
};

const {
  title,
  description,
  canonicalPath,
  lang,
  heading,
  updatedAt,
  homeHref,
  languageLabel,
  languageHref,
  languageCode,
  alternates,
  sections
} = Astro.props;
---

<BaseLayout title={title} description={description} canonicalPath={canonicalPath} lang={lang} alternates={alternates}>
  <main class="legal-shell">
    <nav aria-label="Navigation">
      <a class="brand" href={homeHref}>ONNELLAB</a>
      <a class="language" href={languageHref} data-locale-choice={languageCode} aria-label={lang === 'ko' ? 'Switch to English' : '한국어로 보기'} title={languageLabel}>{languageLabel}</a>
    </nav>

    <header>
      <p class="eyebrow">ONNELLAB</p>
      <h1>{heading}</h1>
      <p class="updated">Last updated: <time datetime={updatedAt}>{updatedAt}</time></p>
    </header>

    <div class="legal-content">
      {sections.map((section) => (
        <section aria-labelledby={section.title.toLowerCase().replaceAll(' ', '-')}>
          <h2 id={section.title.toLowerCase().replaceAll(' ', '-')}>{section.title}</h2>
          {section.body.map((paragraph) => <p>{paragraph}</p>)}
        </section>
      ))}
    </div>
  </main>
</BaseLayout>

<style>
  .legal-shell {
    width: min(860px, calc(100% - 36px));
    margin: 0 auto;
    padding: 28px 0 56px;
    line-height: 1.75;
  }

  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }

  .brand,
  .language {
    color: #68645c;
    text-decoration: none;
  }

  .brand {
    font-size: 14px;
    font-weight: 620;
  }

  .language {
    min-height: 34px;
    display: inline-flex;
    align-items: center;
    border: 1px solid #ded6ca;
    border-radius: 999px;
    padding: 7px 13px;
    background: rgba(255, 253, 248, 0.76);
    font-size: 13px;
    font-weight: 560;
  }

  header {
    margin: 76px 0 34px;
  }

  .eyebrow {
    margin: 0 0 12px;
    color: #777268;
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
  }

  h1 {
    max-width: 760px;
    margin: 0;
    color: #282723;
    font-size: clamp(38px, 6vw, 68px);
    line-height: 1.02;
  }

  .updated {
    margin: 18px 0 0;
    color: #777268;
    font-size: 14px;
  }

  .legal-content {
    display: grid;
    gap: 22px;
  }

  section {
    border-top: 1px solid #e5ded4;
    padding-top: 22px;
  }

  h2 {
    margin: 0 0 10px;
    color: #34322d;
    font-size: 22px;
    line-height: 1.25;
  }

  p {
    margin: 10px 0 0;
    color: #4d4942;
    font-size: 16px;
  }

  @media (max-width: 640px) {
    .legal-shell {
      width: min(100% - 28px, 860px);
      padding-top: 22px;
    }

    header {
      margin-top: 52px;
    }
  }
</style>
