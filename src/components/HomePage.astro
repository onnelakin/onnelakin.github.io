---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getProductIndexItems, type Locale, type ProductIndexItem } from '../lib/products';

type Props = {
  locale: Locale;
};

const { locale } = Astro.props;
const contentApps = getProductIndexItems(locale);
const privacyApps = contentApps.filter((app) => app.privacy);
const contentAppTitles = new Set(contentApps.map((app) => app.title));
const releasedApps = ['Quivra', 'TagWeaver', 'VaultXT', 'Segra', 'ClipNest', 'Aligna'];
const releasedAppCards = releasedApps
  .map((name) => contentApps.find((app) => app.title === name))
  .filter((app): app is ProductIndexItem => app !== undefined);
const staticPrivacyApps = [
  ['Quivra', 'https://onnelakin.github.io/quivra-privacy-policy/'],
  ['TagWeaver', 'https://onnelakin.github.io/tagweaver-privacy-policy/'],
  ['VaultXT', 'https://onnelakin.github.io/vaultxt-privacy-policy/'],
  ['Segra', 'https://onnelakin.github.io/segra-privacy-policy/'],
  ['ClipNest', 'https://onnelakin.github.io/clipnest-privacy-policy/'],
  ['Melivra', 'https://onnelakin.github.io/melivra-privacy-policy/']
].filter(([title]) => !contentAppTitles.has(title));

const text =
  locale === 'ko'
    ? {
        title: 'ONNELLAB - 조용하고 구조적인 디지털 도구',
        description:
          'ONNELLAB은 음악, 텍스트, 오디오, 파일, 생산성을 위한 조용하고 구조적인 앱을 만드는 독립 소프트웨어 스튜디오입니다.',
        intro:
          '일상적인 디지털 작업을 위한 조용하고 구조적인 도구를 만드는 독립 소프트웨어 스튜디오입니다.',
        focus:
          'ONNELLAB은 하나의 일을 잘 해내는 가볍고 개인정보를 존중하는 앱에 집중합니다.',
        released: '출시된 앱',
        allApps: '전체 앱 페이지',
        allAppsHref: '/apps/ko/',
        openApp: '열기',
        upcoming: '예정 프로젝트',
        privacy: '개인정보처리방침',
        contact: '문의',
        inquiry: '문의:',
        soon: '출시 예정',
        switchLabel: 'English',
        switchHref: '/'
      }
    : {
        title: 'ONNELLAB - Calm, Structured Digital Tools',
        description:
          'ONNELLAB is an independent software studio creating calm, structured apps for music, text, audio, files, and productivity.',
        intro:
          'Independent software studio creating calm, structured tools for everyday digital work.',
        focus:
          'ONNELLAB focuses on lightweight, privacy-conscious applications designed to do one job well.',
        released: 'Released Apps',
        allApps: 'All app pages',
        allAppsHref: '/apps/',
        openApp: 'Open',
        upcoming: 'Upcoming Projects',
        privacy: 'Privacy Policy',
        contact: 'Contact',
        inquiry: 'For inquiries:',
        soon: 'Coming Soon',
        switchLabel: '한국어',
        switchHref: '/ko/'
      };
---

<BaseLayout
  title={text.title}
  description={text.description}
  canonicalPath={locale === 'ko' ? '/ko/' : '/'}
  lang={locale}
>
  <link
    slot="head"
    rel="alternate"
    hreflang={locale === 'ko' ? 'en' : 'ko'}
    href={new URL(text.switchHref, Astro.site)}
  />
  <main class="page-shell">
    <nav aria-label="Language">
      <a href={text.switchHref}>{text.switchLabel}</a>
    </nav>

    <h1>ONNELLAB</h1>

    <p>{text.intro}</p>

    <p>{text.focus}</p>

    <h2>{text.released}</h2>

    <section class="app-grid" aria-label={text.released}>
      {releasedAppCards.map((app) => (
        <article>
          <img src={app.iconPath} alt={`${app.title} icon`} width="56" height="56" />
          <div>
            <h3>{app.title}</h3>
            <p>{app.description}</p>
            <span>{app.status} · {app.platforms.join(' · ')}</span>
          </div>
          <a href={app.href}>{text.openApp}</a>
        </article>
      ))}
      <article class="upcoming-card">
        <div class="placeholder" aria-hidden="true">M</div>
        <div>
          <h3>Melivra</h3>
          <p>{text.soon}</p>
          <span>{text.upcoming}</span>
        </div>
      </article>
    </section>

    <p><a href={text.allAppsHref}>{text.allApps}</a></p>

    <h2>{text.upcoming}</h2>

    <ul>
      <li>FloMo</li>
      <li>Nunote</li>
      <li>Textoria</li>
      <li>Heara</li>
    </ul>

    <h2>{text.privacy}</h2>

    <ul>
      {privacyApps.map((app) => <li><a href={app.privacy}>{app.title}</a></li>)}
      {staticPrivacyApps.map(([name, href]) => <li><a href={href}>{name}</a></li>)}
    </ul>

    <h2>{text.contact}</h2>

    <p>
      {text.inquiry}
      {' '}
      <a href="mailto:onnellab.app@gmail.com">onnellab.app@gmail.com</a>
    </p>
  </main>
</BaseLayout>

<style>
  .page-shell {
    max-width: 820px;
    margin: 80px auto;
    padding: 0 24px;
    line-height: 1.75;
  }

  nav {
    text-align: right;
    font-size: 14px;
  }

  nav a {
    text-decoration: none;
  }

  h1 {
    font-weight: 600;
    margin-bottom: 8px;
    letter-spacing: 0;
  }

  h2 {
    margin-top: 48px;
    font-weight: 600;
    letter-spacing: 0;
  }

  p {
    margin: 12px 0;
  }

  ul {
    padding-left: 20px;
  }

  .app-grid {
    display: grid;
    gap: 12px;
    margin: 18px 0 12px;
  }

  article {
    display: grid;
    grid-template-columns: 56px 1fr auto;
    align-items: center;
    gap: 16px;
    border: 1px solid #e0d8cb;
    border-radius: 8px;
    padding: 14px;
    background: #fffdf8;
  }

  img,
  .placeholder {
    width: 56px;
    height: 56px;
    border-radius: 14px;
    background: #eee8dd;
  }

  .placeholder {
    display: grid;
    place-items: center;
    color: #827d72;
    font-weight: 650;
  }

  h3 {
    margin: 0 0 4px;
    font-size: 18px;
    line-height: 1.25;
    letter-spacing: 0;
  }

  article p {
    margin: 0;
    color: #4f4b43;
    font-size: 15px;
    line-height: 1.5;
  }

  article span {
    display: block;
    margin-top: 6px;
    color: #827d72;
    font-size: 13px;
    line-height: 1.4;
  }

  article a {
    border: 1px solid #d6cec0;
    border-radius: 8px;
    padding: 8px 11px;
    background: #faf8f5;
    text-decoration: none;
    font-weight: 620;
    line-height: 1.2;
  }

  .upcoming-card {
    color: #5b574f;
  }

  small {
    color: #777;
  }

  @media (max-width: 680px) {
    .page-shell {
      margin: 48px auto;
      padding: 0 18px;
    }

    article {
      grid-template-columns: 52px 1fr;
    }

    img,
    .placeholder {
      width: 52px;
      height: 52px;
      border-radius: 13px;
    }

    article a {
      grid-column: 1 / -1;
      text-align: center;
    }
  }
</style>
