---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getBlogPosts, renderMarkdownBlocks } from '../../../lib/blog';

export function getStaticPaths() {
  return getBlogPosts('ko').map((post) => ({ params: { slug: post.meta.slug }, props: { post } }));
}

const { post } = Astro.props;
const blocks = renderMarkdownBlocks(post.body);
---

<BaseLayout
  title={`${post.meta.title} - ONNELLAB Blog`}
  description={post.meta.description}
  canonicalPath={post.href}
  lang="ko"
  alternates={[{ lang: 'ko', path: post.href }]}
>
  <main class="article-shell">
    <nav class="top-nav"><a href="/blog/ko/">Blog</a><a href="/ko/">ONNELLAB</a></nav>
    <article>
      <header>
        <p>{post.meta.category}</p>
        <h1>{post.meta.title}</h1>
        <span>{post.meta.description}</span>
      </header>
      <div class="article-body">
        {blocks.map((block) => {
          if (block.type === 'h2') return <h2>{block.value}</h2>;
          if (block.type === 'h3') return <h3>{block.value}</h3>;
          if (block.type === 'ul') return <ul>{(block.value as string[]).map((item) => <li>{item}</li>)}</ul>;
          if (block.type === 'ol') return <ol>{(block.value as string[]).map((item) => <li>{item}</li>)}</ol>;
          return <p>{block.value}</p>;
        })}
      </div>
    </article>
  </main>
</BaseLayout>

<style>
  .article-shell { width: min(820px, calc(100% - 40px)); margin: 0 auto; padding: 22px 0 64px; line-height: 1.75; }
  .top-nav { display: flex; justify-content: space-between; margin-bottom: 48px; font-size: 14px; }
  .top-nav a { color: #5f5a50; text-decoration: none; font-weight: 650; }
  header { padding-bottom: 28px; border-bottom: 1px solid #e0d8cb; }
  header p { margin: 0 0 12px; color: #716a5f; font-size: 13px; font-weight: 720; text-transform: uppercase; }
  h1 { margin: 0; color: #2f2f2f; font-size: clamp(34px, 6vw, 60px); line-height: 1.12; letter-spacing: 0; }
  header span { display: block; max-width: 680px; margin-top: 18px; color: #5d5850; font-size: 18px; }
  .article-body { padding-top: 28px; }
  h2 { margin: 34px 0 10px; color: #343331; font-size: 26px; line-height: 1.2; }
  h3 { margin: 26px 0 8px; color: #343331; font-size: 20px; }
  p, li { color: #4f4b45; }
  ul, ol { padding-left: 24px; }
</style>
